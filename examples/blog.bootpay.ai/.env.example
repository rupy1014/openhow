# ─────────────────────────────────────────────────────────────
# Bootpay YouTube 환경 변수 설정
# .env 파일로 복사 후 실제 값을 입력하세요
# ─────────────────────────────────────────────────────────────

# ElevenLabs (메인 TTS — 1인 설명 narrator)
# 비용: Starter $5/월 (~30,000자)
# 가입: https://elevenlabs.io/
ELEVEN_LABS_API_KEY=
ELEVEN_LABS_VOICE_ID=              # narrator 목소리 ID

# Fish Audio (백업용)
FISH_AUDIO_API_KEY=
FISH_AUDIO_VOICE_ID=

# Kie.ai InfiniteTalk (립싱크)
# 비용: 480p $0.015/초
KIE_AI_API_KEY=
